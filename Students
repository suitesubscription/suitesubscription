    }
    .nav-logo {
      font-family: 'Space Mono', monospace;
      font-size: 14px; font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--green);
      text-decoration: none;
    }
    .nav-logo span { color: var(--yellow); }
    .nav-cta {
